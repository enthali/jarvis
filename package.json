{
  "name": "jarvis",
  "displayName": "Jarvis",
  "description": "Personal assistant for managing projects and events in VS Code",
  "version": "0.3.0",
  "publisher": "enthali",
  "repository": {
    "type": "git",
    "url": "https://github.com/enthali/Jarvis.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:jarvisProjects",
    "onView:jarvisEvents",
    "onView:jarvisMessages",
    "onView:jarvisHeartbeat"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jarvis-explorer",
          "title": "Jarvis",
          "icon": "resources/jarvis.svg"
        }
      ]
    },
    "views": {
      "jarvis-explorer": [
        {
          "id": "jarvisProjects",
          "name": "Projects"
        },
        {
          "id": "jarvisEvents",
          "name": "Events"
        },
        {
          "id": "jarvisMessages",
          "name": "Messages"
        },
        {
          "id": "jarvisHeartbeat",
          "name": "Heartbeat"
        }
      ]
    },
    "commands": [
      {
        "command": "jarvis.filterProjectFolders",
        "title": "Filter Project Folders",
        "icon": "$(filter)"
      },
      {
        "command": "jarvis.filterProjectFoldersActive",
        "title": "Filter Project Folders",
        "icon": "$(filter-filled)"
      },
      {
        "command": "jarvis.filterFutureEvents",
        "title": "Show Future Events Only",
        "icon": "$(filter)"
      },
      {
        "command": "jarvis.filterFutureEventsActive",
        "title": "Show Future Events Only",
        "icon": "$(filter-filled)"
      },
      {
        "command": "jarvis.openYamlFile",
        "title": "Open YAML File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "jarvis.runHeartbeatJob",
        "title": "Jarvis: Run Heartbeat Job"
      },
      {
        "command": "jarvis.sendMessages",
        "title": "Jarvis: Send Messages to Chat Session",
        "icon": "$(debug-start)"
      },
      {
        "command": "jarvis.deleteMessage",
        "title": "Jarvis: Delete Queued Message",
        "icon": "$(trash)"
      },
      {
        "command": "jarvis.openSession",
        "title": "Jarvis: Open Chat Session"
      },
      {
        "command": "jarvis.openAgentSession",
        "title": "Jarvis: Open Agent Session",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "jarvis.newProject",
        "title": "Jarvis: New Project",
        "icon": "$(add)"
      },
      {
        "command": "jarvis.newEvent",
        "title": "Jarvis: New Event",
        "icon": "$(add)"
      },
      {
        "command": "jarvis.checkForUpdates",
        "title": "Jarvis: Check for Updates"
      },
      {
        "command": "jarvis.rescan",
        "title": "Jarvis: Rescan",
        "icon": "$(refresh)"
      },
      {
        "command": "jarvis.runJob",
        "title": "Jarvis: Run Job",
        "icon": "$(play)"
      },
      {
        "command": "jarvis.refreshHeartbeat",
        "title": "Jarvis: Refresh Heartbeat",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "jarvis.openAgentSession",
          "when": "false"
        },
        {
          "command": "jarvis.newProject",
          "when": "false"
        },
        {
          "command": "jarvis.newEvent",
          "when": "false"
        },
        {
          "command": "jarvis.rescan",
          "when": "false"
        },
        {
          "command": "jarvis.runJob",
          "when": "false"
        },
        {
          "command": "jarvis.refreshHeartbeat",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "jarvis.newProject",
          "when": "view == jarvisProjects",
          "group": "navigation@1"
        },
        {
          "command": "jarvis.filterProjectFolders",
          "when": "view == jarvisProjects && !jarvis.projectFilterActive",
          "group": "navigation@2"
        },
        {
          "command": "jarvis.filterProjectFoldersActive",
          "when": "view == jarvisProjects && jarvis.projectFilterActive",
          "group": "navigation@2"
        },
        {
          "command": "jarvis.rescan",
          "when": "view == jarvisProjects",
          "group": "navigation@3"
        },
        {
          "command": "jarvis.newEvent",
          "when": "view == jarvisEvents",
          "group": "navigation@1"
        },
        {
          "command": "jarvis.filterFutureEvents",
          "when": "view == jarvisEvents && !jarvis.eventFilterActive",
          "group": "navigation@2"
        },
        {
          "command": "jarvis.filterFutureEventsActive",
          "when": "view == jarvisEvents && jarvis.eventFilterActive",
          "group": "navigation@2"
        },
        {
          "command": "jarvis.rescan",
          "when": "view == jarvisEvents",
          "group": "navigation@3"
        },
        {
          "command": "jarvis.refreshHeartbeat",
          "when": "view == jarvisHeartbeat",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "jarvis.openYamlFile",
          "when": "viewItem == jarvisProject",
          "group": "inline"
        },
        {
          "command": "jarvis.openYamlFile",
          "when": "viewItem == jarvisEvent",
          "group": "inline"
        },
        {
          "command": "jarvis.sendMessages",
          "when": "viewItem == messageSession",
          "group": "inline"
        },
        {
          "command": "jarvis.deleteMessage",
          "when": "viewItem == messageItem",
          "group": "inline"
        },
        {
          "command": "jarvis.openAgentSession",
          "when": "viewItem == jarvisProject",
          "group": "inline"
        },
        {
          "command": "jarvis.openAgentSession",
          "when": "viewItem == jarvisEvent",
          "group": "inline"
        },
        {
          "command": "jarvis.runJob",
          "when": "viewItem == heartbeatJob",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Jarvis",
      "properties": {
        "jarvis.projectsFolder": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the folder containing project YAML files."
        },
        "jarvis.eventsFolder": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the folder containing event YAML files."
        },
        "jarvis.scanInterval": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "description": "Background rescan interval in minutes (0 = disabled, registers via heartbeat)."
        },
        "jarvis.heartbeatConfigFile": {
          "type": "string",
          "default": "",
          "description": "Absolute path to heartbeat.yaml. Defaults to workspace storage if empty."
        },
        "jarvis.heartbeatInterval": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "description": "Heartbeat scheduler tick interval in seconds (minimum 10)."
        },
        "jarvis.messagesFile": {
          "type": "string",
          "default": "",
          "description": "Absolute path to messages.json queue file. Defaults to extension storage if empty."
        },
        "jarvis.checkForUpdates": {
          "type": "boolean",
          "default": true,
          "description": "Check for new Jarvis releases on GitHub when the extension activates."
        },
        "jarvis.mcpPort": {
          "type": "number",
          "default": 31415,
          "description": "Port for the embedded MCP server (localhost only)."
        },
        "jarvis.mcpEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the embedded MCP server."
        }
      }
    },
    "languageModelTools": [
      {
        "name": "jarvis_sendToSession",
        "displayName": "Send Message to Chat Session",
        "modelDescription": "Queues a message for delivery to another VS Code chat session identified by name. The message appears in the Jarvis Messages explorer and can be delivered to the target session. Always set senderSession to your own session name so the receiver knows who sent the message.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "sendToSession",
        "icon": "$(comment-discussion)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "session": {
              "type": "string",
              "description": "The exact name/title of the destination chat session"
            },
            "senderSession": {
              "type": "string",
              "description": "Your own session/tab name so the receiver knows who sent this message"
            },
            "text": {
              "type": "string",
              "description": "The message text to send to the target session"
            }
          },
          "required": [
            "session",
            "text"
          ]
        }
      },
      {
        "name": "jarvis_listSessions",
        "displayName": "List Chat Sessions",
        "modelDescription": "Returns the list of named chat session titles in the current workspace. Use this to discover valid session names before sending messages via sendToSession.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "listSessions",
        "icon": "$(list-unordered)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "jarvis_readMessage",
        "displayName": "Read Message from Inbox",
        "modelDescription": "Reads and removes the oldest message from the Jarvis message queue for the given destination session. Returns the message (sender, text, timestamp) and the count of remaining messages. Call repeatedly until remaining is 0 to read all messages.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "readMessage",
        "icon": "$(mail-read)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "destination": {
              "type": "string",
              "description": "The exact name/title of the destination chat session whose messages to read"
            }
          },
          "required": [
            "destination"
          ]
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cron-parser": "^5.5.0",
    "js-yaml": "^4.1.1",
    "sql.js": "^1.14.1"
  }
}
