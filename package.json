{
  "name": "jarvis",
  "displayName": "Jarvis",
  "description": "Personal assistant for managing projects and events in VS Code",
  "version": "0.0.1",
  "publisher": "jarvis",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:jarvisProjects",
    "onView:jarvisEvents"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jarvis-explorer",
          "title": "Jarvis",
          "icon": "resources/jarvis.svg"
        }
      ]
    },
    "views": {
      "jarvis-explorer": [
        {
          "id": "jarvisProjects",
          "name": "Projects"
        },
        {
          "id": "jarvisEvents",
          "name": "Events"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0"
  }
}
